{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/admin",
      "destination": "https://api.tk168.co.jp/admin",
      "permanent": false
    },
    {
      "source": "/admin/:path*",
      "destination": "https://api.tk168.co.jp/admin/:path*",
      "permanent": false
    },
    {
      "source": "/admin.html",
      "destination": "https://api.tk168.co.jp/admin",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(html|js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
